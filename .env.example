# ─────────────────────────────────────────────────────────────
# HYDRA Arm 3 — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── Wallet Configuration ────────────────────────────────────
# Ethereum/Base wallet address that receives USDC payments
WALLET_ADDRESS=0x2F12A73e1e08F3BCE12212005cCaBE2ACEf87141

# Base L2 RPC endpoint (default: public Base mainnet endpoint)
# For production, use a private RPC from Alchemy, QuickNode, or Coinbase
BASE_RPC_URL=https://mainnet.base.org

# USDC contract on Base mainnet (do not change unless testing on a different network)
USDC_CONTRACT_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Private key for the wallet (required for remittance transfers)
# Without this, the automaton runs in read-only mode
# WALLET_PRIVATE_KEY=0x...

# ── State Directory ────────────────────────────────────────
# Directory for persistent state files (state.json, transactions.jsonl, remittance-config.json)
HYDRA_STATE_DIR=/app/data

# ── Application Settings ────────────────────────────────────
# Set DEBUG=true for verbose logging and auto-reload (development only)
DEBUG=false

# Server host and port (port 8402 — HTTP 402 reference)
HOST=0.0.0.0
PORT=8402

# ── Cache Settings ──────────────────────────────────────────
# How long to cache RSS feed results (seconds). Default: 3600 (1 hour)
FEED_CACHE_TTL=3600

# How long to cache verified payment tx hashes (seconds). Default: 86400 (24 hours)
# This prevents replay attacks — a tx hash is valid for only one API call.
PAYMENT_CACHE_TTL=86400

# ─────────────────────────────────────────────────────────────
# NOTES
# ─────────────────────────────────────────────────────────────
# 
# Payment Flow:
#   1. Client calls POST /v1/regulatory/scan (or any paid endpoint)
#   2. Server returns HTTP 402 with payment instructions
#   3. Client sends USDC to WALLET_ADDRESS on Base (chain 8453)
#   4. Client retries with X-Payment-Proof: <tx_hash> header
#   5. Server verifies tx on Base RPC, checks USDC Transfer event
#   6. If valid, request proceeds and response is returned
#
# Private RPC Recommended for Production:
#   Alchemy:   https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
#   QuickNode: https://api.quicknode.com/graphql
#   Infura:    https://base-mainnet.infura.io/v3/YOUR_KEY
#   Coinbase:  https://api.developer.coinbase.com/rpc/v1/base/YOUR_KEY
#
# Testnet (Base Sepolia):
#   BASE_RPC_URL=https://sepolia.base.org
#   USDC_CONTRACT_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
#   (Use Base Sepolia USDC faucet for testing)
